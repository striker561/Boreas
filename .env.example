# ============================================
# CORE APPLICATION SETTINGS
# ============================================
APP_NAME=Boreas
APP_VERSION=1.0.0
IS_PRODUCTION=false

# ============================================
# REDIS CONFIGURATION
# ============================================
REDIS_URL=redis://localhost:6379/0


# ============================================
# CORS & NETWORK SECURITY
# ============================================
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
TRUSTED_HOSTS=localhost,127.0.0.1


# ============================================
# REQUEST LIMITS & ABUSE PROTECTION
# ============================================
MAX_BODY_SIZE=10485760
GZIP_MIN_SIZE=1024
API_RATE_LIMIT=5/minute
UPLOAD_RATE_LIMIT=5/minute
JOB_TTL_SECONDS=3600
RESULT_URL_TTL_SECONDS=3600
MEDIA_SOURCE_MAX_BYTES=2097152
MEDIA_STAGING_TTL_SECONDS=900


# ============================================
# OBSERVABILITY
# ============================================
LOG_LEVEL=INFO
LOGFIRE_SEND_TO_LOGFIRE=false
LOGFIRE_TOKEN=
LOGFIRE_SERVICE_NAME=boreas
LOGFIRE_ENVIRONMENT=development


# ============================================
# WORKER CONFIG
# ============================================
MEDIA_WORKERS=1
BACKGROUND_REMOVAL_WORKERS=1

# ============================================
# OBJECT STORAGE (S3-compatible)
# ============================================
STORAGE_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
STORAGE_ACCESS_KEY_ID=your-access-key-id
STORAGE_SECRET_ACCESS_KEY=your-secret-access-key
STORAGE_BUCKET_NAME=boreas-media
STORAGE_REGION=auto

# ============================================
# REMBG
# ============================================
REMBG_MODEL=isnet-general-use
REMBG_POST_PROCESS_MASK=true
REMBG_ALPHA_MATTING=false
REMBG_ALPHA_MATTING_FOREGROUND_THRESHOLD=240
REMBG_ALPHA_MATTING_BACKGROUND_THRESHOLD=10
REMBG_ALPHA_MATTING_ERODE_SIZE=10
REMBG_OMP_NUM_THREADS=2
